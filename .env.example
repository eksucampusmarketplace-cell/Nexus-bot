# ── Required ──────────────────────────────────────────────
PRIMARY_BOT_TOKEN=your_primary_token
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_key
SUPABASE_CONNECTION_STRING=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
SECRET_KEY=your_fernet_key  # Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
OWNER_ID=123456789

# ── Bot Display & Support ────────────────────────────────────────────────
BOT_DISPLAY_NAME=Nexus  # Displayed in "Powered by {bot_name}"
MAIN_BOT_USERNAME=NexusBot  # Username for support redirects
SUPPORT_GROUP_ID=0  # Internal alerts group (0 = disabled)
DOCS_URL=https://docs.example.com  # Documentation link
MINI_APP_URL=  # Optional: Custom Mini App URL. If not set, defaults to {RENDER_EXTERNAL_URL}/webapp

# ── Alert Settings ────────────────────────────────────────────────────────
ALERT_ON_ERRORS=true  # Post errors to support group
ALERT_ON_NEW_CLONES=true  # Post new clone registrations
ALERT_ON_DEAD_CLONES=true  # Post when clone token becomes invalid

# ── Access control ────────────────────────────────────────
CLONE_ACCESS=owner_only   # owner_only | anyone

# ── Music Settings ────────────────────────────────────────────
MUSIC_WORKER_COUNT=1          # Number of userbot accounts for main bot music
MUSIC_MAX_QUEUE=50             # Maximum tracks in queue
MUSIC_MAX_DURATION=3600        # Max track duration in seconds (1 hour)
MUSIC_IDLE_TIMEOUT=180         # Leave VC after X seconds idle (3 minutes)
MUSIC_DEFAULT_VOLUME=100        # Default volume (0-200)
MUSIC_DOWNLOAD_DIR=/tmp/nexus_music  # Temp directory for downloaded audio

# Pyrogram API credentials (required for music userbot)
# Get from https://my.telegram.org/apps
PYROGRAM_API_ID=12345678
PYROGRAM_API_HASH=your_api_hash_here

# ── Dev / debug ───────────────────────────────────────────
SKIP_AUTH=false           # true for local dev only — never deploy true
DEBUG=false               # true enables /debug/* routes

# ── Auto-set by Render ────────────────────────────────────
PORT=8000
RENDER_EXTERNAL_URL=https://your-app.onrender.com

# ── Legacy (optional) ─────────────────────────────────────
# CLONE_TOKENS=token2,token3  # Legacy - no longer needed, use /clone instead
