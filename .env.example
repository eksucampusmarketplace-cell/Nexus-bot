# Nexus Bot Environment Configuration
# Copy this file to .env and fill in your values

# ── Required Settings ─────────────────────────────────────────────────────

# Primary Bot Token
# Get from @BotFather on Telegram
PRIMARY_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Supabase Configuration
# Get from https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_CONNECTION_STRING=postgresql://postgres:[YOUR-PASSWORD]@db.your-project.supabase.co:5432/postgres

# Encryption Key for Clone Tokens
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=your-32-character-secret-key-here

# ── Optional Settings ─────────────────────────────────────────────────────

# Owner User ID (for admin access)
OWNER_ID=123456789

# Skip authentication (for development only!)
SKIP_AUTH=false

# Debug mode
DEBUG=false

# Server Port
PORT=8000

# Render External URL (auto-set on Render)
RENDER_EXTERNAL_URL=https://your-app.onrender.com

# Clone Access Mode: owner_only | anyone
CLONE_ACCESS=owner_only

# ── Bot Display & Support ───────────────────────────────────────────────────

BOT_DISPLAY_NAME=Nexus
MAIN_BOT_USERNAME=NexusBot
SUPPORT_GROUP_ID=0  # Set to your support group chat ID to receive alerts
DOCS_URL=https://github.com/yourusername/nexus-bot/wiki
MINI_APP_URL=  # Leave empty to use RENDER_EXTERNAL_URL/miniapp
PRIVACY_POLICY_URL=  # Leave empty to use default GitHub/inline

# ── Alert Settings ─────────────────────────────────────────────────────────

ALERT_ON_ERRORS=true
ALERT_ON_NEW_CLONES=true
ALERT_ON_DEAD_CLONES=true

# ── Music Settings ─────────────────────────────────────────────────────────

MUSIC_WORKER_COUNT=1
MUSIC_MAX_QUEUE=50
MUSIC_MAX_DURATION=1800  # seconds (30min) - reduced from 1hr for bandwidth optimization
MUSIC_IDLE_TIMEOUT=180  # seconds (3min)
MUSIC_DEFAULT_VOLUME=100  # 0-200
MUSIC_DOWNLOAD_DIR=/tmp/nexus_music
MUSIC_DOWNLOADS_PER_HOUR=15  # Bandwidth limit per group per hour
MUSIC_YTDLP_VERSION=2024.3.10
MUSIC_MAX_RETRIES=3
MUSIC_JOB_TTL=3600
MUSIC_SERVICE_TIMEOUT=10

# ── Pyrogram API Credentials ───────────────────────────────────────────────
# Get from https://my.telegram.org/apps
PYROGRAM_API_ID=12345678
PYROGRAM_API_HASH=abcdefghijklmnopqrstuvwxyz123456

# ── Redis Configuration ───────────────────────────────────────────────────

REDIS_URL=redis://localhost:6379

# ── Memory Management ───────────────────────────────────────────────────────

PYROGRAM_MAX_ACTIVE=10
LAZY_UNLOAD_TIMEOUT=1800  # seconds (30min)
MEMORY_WARN_MB=800
MEMORY_CRITICAL_MB=1200

# ── Stars Economy ─────────────────────────────────────────────────────────

REFERRAL_BONUS_STARS=100
REFERRAL_REFERRED_BONUS=50

# ── Bandwidth Optimization (NEW) ─────────────────────────────────────────────
# These settings help reduce outbound bandwidth usage on Render

# Enable bandwidth tracking (true/false)
BANDWIDTH_TRACKING_ENABLED=true

# Bandwidth alert thresholds in MB
BANDWIDTH_WARN_MB=1
BANDWIDTH_ALERT_MB=10

# Enable aggressive caching (true/false)
AGGRESSIVE_CACHING=false

# ── Notes ──────────────────────────────────────────────────────────────────
#
# Bandwidth Optimization Tips:
# 1. MUSIC_MAX_DURATION=1800 (30min) prevents streaming very long tracks
# 2. MUSIC_DOWNLOADS_PER_HOUR=15 limits downloads per group
# 3. Medium quality audio is used by default (configurable in music_service.py)
# 4. Gzip compression is enabled by default for API responses
# 5. See BANDWIDTH_OPTIMIZATION.md for more details
#
# To further reduce bandwidth:
# - Consider upgrading to MediumQualityAudio instead of HighQualityAudio (already done)
# - Enable aggressive caching for frequently accessed data
# - Use the bandwidth_tracker.py middleware to identify heavy endpoints
# - Implement the frontend optimizations in bandwidth_optimization.js
