# Music Worker Local Configuration
# Copy this file to .env.music and fill in your actual values

# Telegram API credentials (get from https://my.telegram.org/apps)
PYROGRAM_API_ID=12345678
PYROGRAM_API_HASH=your_api_hash_here

# Supabase/PostgreSQL connection (same as main bot)
SUPABASE_CONNECTION_STRING=postgresql://postgres:password@db.xxxxxxxx.supabase.co:5432/postgres

# Redis URL (same as main bot)
REDIS_URL=redis://localhost:6379

# Bot token (optional, for sending now-playing messages)
BOT_TOKEN=your_bot_token_here

# Music download directory
MUSIC_DOWNLOAD_DIR=/tmp/nexus_music

# Maximum track duration in seconds (1 hour default)
MUSIC_MAX_DURATION=3600

# Lazy client timeout (seconds)
LAZY_UNLOAD_TIMEOUT=1800

# Maximum active Pyrogram clients
PYROGRAM_MAX_ACTIVE=10

# Encryption key (same as main bot's SECRET_KEY)
SECRET_KEY=your_fernet_key_here
