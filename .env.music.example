# Music Worker Local Configuration (Standalone)
# Copy this file to .env.music and fill in your actual values
#
# NOTE: Most users should just add these variables to the main .env file.
# This separate file is only needed if running music worker standalone.

# ═══════════════════════════════════════════════════════════
# Required - Pyrogram API Credentials
# ═══════════════════════════════════════════════════════════
# Get from https://my.telegram.org/apps
PYROGRAM_API_ID=12345678
PYROGRAM_API_HASH=your_api_hash_here

# ═══════════════════════════════════════════════════════════
# Required - Database & Redis (same as main bot)
# ═══════════════════════════════════════════════════════════
SUPABASE_CONNECTION_STRING=postgresql://postgres:password@db.xxxxxxxx.supabase.co:5432/postgres
REDIS_URL=redis://localhost:6379

# ═══════════════════════════════════════════════════════════
# Required - Encryption Key
# ═══════════════════════════════════════════════════════════
# MUST match the SECRET_KEY in your main .env file!
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=your_fernet_key_here

# ═══════════════════════════════════════════════════════════
# Optional - Bot Token (for sending now-playing messages)
# ═══════════════════════════════════════════════════════════
BOT_TOKEN=your_bot_token_here

# ═══════════════════════════════════════════════════════════
# Optional - Music Configuration
# ═══════════════════════════════════════════════════════════
# Directory for temporary audio files (must be writable)
MUSIC_DOWNLOAD_DIR=/tmp/nexus_music

# Maximum track duration in seconds (default: 1 hour = 3600)
MUSIC_MAX_DURATION=3600

# Seconds of inactivity before leaving voice chat (default: 3 min = 180)
MUSIC_IDLE_TIMEOUT=180

# Default volume 0-200 (default: 100)
MUSIC_DEFAULT_VOLUME=100

# Maximum tracks in queue (default: 50)
MUSIC_MAX_QUEUE=50

# ═══════════════════════════════════════════════════════════
# Optional - Memory Management
# ═══════════════════════════════════════════════════════════
# Maximum simultaneous Pyrogram clients (default: 10)
PYROGRAM_MAX_ACTIVE=10

# Seconds before unloading idle client (default: 30 min = 1800)
LAZY_UNLOAD_TIMEOUT=1800

# Memory warning threshold in MB (default: 800)
MEMORY_WARN_MB=800

# Force unload threshold in MB (default: 1200)
MEMORY_CRITICAL_MB=1200
